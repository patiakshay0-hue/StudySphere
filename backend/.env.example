# StudySphere environment configuration
# Copy this file to ".env" and fill in your values. NEVER commit real secrets.

# --- AI (Online / Premium mode) ---------------------------------------------
# Enables Claude-powered answers, quizzes, papers, and summaries (online mode).
# Without a key, online mode is disabled server-side; offline mode still works.
ANTHROPIC_API_KEY=
STUDYSPHERE_MODEL=claude-opus-4-8
STUDYSPHERE_TOP_K=5

# --- Authentication ---------------------------------------------------------
# Secret used to sign JWT login tokens. REQUIRED in production (set a long random
# value). If left blank locally, one is generated and persisted automatically.
JWT_SECRET=

# --- Payments (Razorpay) ----------------------------------------------------
# Get keys at https://dashboard.razorpay.com/ (Settings -> API Keys).
# If left blank, StudySphere uses a MOCK payment flow so you can demo upgrades
# without real keys. Set both to go live with real Razorpay Checkout.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Storage / hosting ------------------------------------------------------
# Directory for the SQLite database. In production point this at a persistent
# disk/volume (e.g. /data) so accounts and uploads survive restarts.
STUDYSPHERE_DATA_DIR=
